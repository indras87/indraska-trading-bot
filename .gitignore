# ===== Secrets / credentials — NEVER commit =====
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ===== Runtime state (all writable files live here; shared volume in docker) =====
runtime/*
!runtime/.gitkeep
executor/state.json
executor/state.tmp
executor/orders_history.jsonl
executor/state.json.bak
executor/orders_history.jsonl.bak
executor/executor.log
KILL_SWITCH
**/KILL_SWITCH
signals/latest_signal.json
signals/*.json
!signals/.gitkeep

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
venv/
.venv/
env/

# ===== Logs / reports (regenerated) =====
*.log
logs/

# ===== OS / editor =====
.DS_Store
.idea/
.vscode/
*.swp
