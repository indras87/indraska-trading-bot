# =====================================================================
# Executor .env example — copy to executor/.env and fill.
# DEFAULT IS TESTNET. BINANCE_TESTNET MUST stay true.
# Only the user, in a separate interactive terminal, may change it.
# Never paste .env contents into chat/commit/logs.
# =====================================================================

# Binance Futures API — TESTNET credentials
# Generate at https://testnet.binancefuture.com
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
BINANCE_TESTNET=true
