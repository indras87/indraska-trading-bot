# =====================================================================
# vibe-trading .env example — research/signal side ONLY.
# This component NEVER sends orders to Binance. It only produces signals.
# Copy to vibe-trading/.env and fill if you want real GLM signals.
# Leave unset to use MOCK signals (testnet end-to-end works without these).
# =====================================================================

# Z.ai GLM Coding Plan (OpenAI-compatible)
# Get a key from your Z.ai Coding Plan dashboard.
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-4.5
