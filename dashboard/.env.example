# =====================================================================
# dashboard .env example — READ-ONLY web UI.
# This component NEVER trades. Binance key here MUST be a SEPARATE
# read-only key (futures read permission only, NO trade permission),
# different from executor/.env. Leave Binance keys empty to run
# file-only mode (shows executor state from state.json).
# =====================================================================

# Token required for the kill-switch toggle endpoint. Set a strong random value.
DASHBOARD_TOKEN=change_me_to_a_long_random_string
PORT=8080

# Optional SEPARATE read-only Binance key (testnet by default).
# Leave empty to disable live position display.
DASHBOARD_BINANCE_API_KEY=
DASHBOARD_BINANCE_API_SECRET=

# Keep testnet read-only by default.
BINANCE_TESTNET=true
